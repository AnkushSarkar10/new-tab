{
  "manifest_version": 2,
  "name": "new tab",
  "version": "0.1.2",
  "description": "want a uniform clean experience when you open a new tab? new tab is your solution. available across all browsers.",
  "permissions": ["storage", "tabs"],
  "background": {
    "scripts": ["scripts/startup.js"]
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "chrome_settings_overrides": {
    "homepage": "newtab.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "album-new-tab@local",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
