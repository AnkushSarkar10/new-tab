{
  "manifest_version": 3,
  "name": "Album New Tab",
  "version": "0.1.0",
  "description": "Replace Chrome's new tab page with a random fullscreen image from the selected album.",
  "permissions": ["storage"],
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  }
}
