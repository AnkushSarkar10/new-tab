{
  "manifest_version": 3,
  "name": "new tab",
  "version": "0.1.2",
  "description": "want a uniform clean experience when you open a new tab? new tab is your solution. available across all browsers.",
  "permissions": ["storage", "tabs"],
  "background": {
    "service_worker": "scripts/startup.js"
  },
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  }
}
